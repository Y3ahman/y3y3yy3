---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Y3ahman">
	<main class="max-w-3xl mx-auto px-4 py-20">

		<!-- Hero Section -->
		<section class="mb-20">
			<p class="text-green-400 text-sm mb-3 tracking-widest uppercase">~/y3ahman</p>
			<h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">
				Hi, I'm
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-500">
					Y3ahman
				</span>
			</h1>
			<p class="text-gray-400 text-lg mb-8">Developer / Builder / Tinkerer</p>
			<div class="flex items-center gap-2 text-sm text-gray-500">
				<span class="text-green-400">❯</span>
				<span class="text-gray-300">cat about.txt</span>
			</div>
			<p class="mt-3 text-gray-400 text-sm leading-relaxed pl-5 border-l border-gray-700">
				Exploring ideas, building things, and leaving digital footprints.
			</p>
		</section>

		<!-- Project Showcase Section -->
		<section>
			<div class="flex items-center gap-3 mb-8">
				<span class="text-green-400">❯</span>
				<h2 class="text-xl font-semibold text-gray-100 tracking-wide">ls ./projects</h2>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
				<!-- Placeholder card 1 -->
				<div class="border border-gray-800 rounded-lg p-6 bg-gray-800/30 hover:border-gray-600 transition-colors">
					<div class="flex items-center gap-2 mb-3">
						<span class="text-purple-400 text-xs font-semibold uppercase tracking-widest">project</span>
					</div>
					<h3 class="text-gray-300 font-semibold mb-2">Coming Soon</h3>
					<p class="text-gray-500 text-sm">This space is reserved for future work. Check back later.</p>
					<div class="mt-4 flex gap-2">
						<span class="text-xs text-gray-600 border border-gray-700 rounded px-2 py-0.5">???</span>
					</div>
				</div>

				<!-- Placeholder card 2 -->
				<div class="border border-gray-800 rounded-lg p-6 bg-gray-800/30 hover:border-gray-600 transition-colors">
					<div class="flex items-center gap-2 mb-3">
						<span class="text-pink-400 text-xs font-semibold uppercase tracking-widest">project</span>
					</div>
					<h3 class="text-gray-300 font-semibold mb-2">Work in Progress</h3>
					<p class="text-gray-500 text-sm">Something is being built here. Stay tuned.</p>
					<div class="mt-4 flex gap-2">
						<span class="text-xs text-gray-600 border border-gray-700 rounded px-2 py-0.5">WIP</span>
					</div>
				</div>
			</div>

			<p class="mt-6 text-gray-600 text-xs text-center">
				<span class="text-green-400">_</span> more to come
			</p>
		</section>

	</main>
</Layout>
